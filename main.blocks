<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" x="10" y="10"><statement name="HANDLER"><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace TinybitPro {" line1="" line2="    // ==========================================" line3="    // 1. CALIBRATION &amp; TUNING VARIABLES" line4="    // ==========================================" line5="" line6="    // Physics Calibration" line7="    export let WHEELBASE = 0.082;           // 8.2 cm distance between wheels" line8="    export let M_PER_PWM_S = 0.00215;       // Meters moved per 1 unit of PWM per second" line9="    export let WHEEL_DIAMETER = 0.065;      // 6.5 cm wheel diameter" line10="" line11="    // PIDF Controller Setup" line12="    export let kP = 1.4;" line13="    export let kI = 0.02;" line14="    export let kD = 0.15;" line15="    export let kF = 35;                     // Friction compensation (minimum power)" line16="" line17="    // Movement Thresholds" line18="    export let DISTANCE_TOLERANCE = 0.01;   // 1cm tolerance" line19="    export let ANGLE_TOLERANCE = 2;         // 2 degree tolerance" line20="    export let SONAR_MAX_RANGE = 1.5;       // 1.5m max" line21="    export let SONAR_MIN_RANGE = 0.05;      // 5cm min" line22="" line23="    // SLAM Setup" line24="    export let GRID_RES = 0.05;             // Map resolution: 5cm per cell" line25="    export let MAP_DIM = 40;                // Map size: 40x40 cells (2m x 2m area)" line26="" line27="    // ==========================================" line28="    // 2. ODOMETRY STATE VARIABLES" line29="    // ==========================================" line30="" line31="    // Robot Pose (Global Coordinates)" line32="    export let x = 0.0, y = 0.0;" line33="    export let theta = 0.0;                 // Heading in Radians" line34="" line35="    // Motor State" line36="    let motorLeftTarget = 0;" line37="    let motorRightTarget = 0;" line38="    let motorLeftActual = 0;" line39="    let motorRightActual = 0;" line40="    let motorLeftError = 0;" line41="    let motorRightError = 0;" line42="" line43="    // PIDF State" line44="    let leftIntegral = 0.0;" line45="    let rightIntegral = 0.0;" line46="    let leftPrevError = 0.0;" line47="    let rightPrevError = 0.0;" line48="    let lastPIDFTime = control.micros();" line49="" line50="    // Timing" line51="    let lastOdomTime = control.micros();" line52="" line53="    // Movement Tracking" line54="    let targetDistance = 0.0;" line55="    let targetAngle = 0.0;" line56="    let isMoving = false;" line57="    let movementMode = 0;  // 0: idle, 1: straight, 2: turn" line58="" line59="    // ==========================================" line60="    // 3. HARDWARE &amp; MEMORY BUFFERS" line61="    // ==========================================" line62="" line63="    // I2C Configuration" line64="    const PWM_ADD = 0x01;" line65="    const MOTOR_REG = 0x02;" line66="    const RGB_REG = 0x01;" line67="" line68="    // Pre-allocated buffers" line69="    let motorBuf = pins.createBuffer(5);" line70="    motorBuf[0] = MOTOR_REG;" line71="" line72="    let rgbBuf = pins.createBuffer(4);" line73="    rgbBuf[0] = RGB_REG;" line74="" line75="    // SLAM Grid" line76="    let mapGrid = pins.createBuffer(MAP_DIM * MAP_DIM);" line77="" line78="    // Sonar History (rolling median window)" line79="    let sonarHistory = [0, 0, 0, 0, 0];" line80="    let sonarIdx = 0;" line81="" line82="    // Encoder simulation (PWM-based)" line83="    let encoderLeftCount = 0;" line84="    let encoderRightCount = 0;" line85="" line86="    // ==========================================" line87="    // 4. INITIALIZATION" line88="    // ==========================================" line89="" line90="    /**" line91="     * Initialize the robot system." line92="     * Call this once at startup." line93="     */" line94="    export function init(): void {" line95="        serial.writeLine(&quot;[INIT] TinyBit Pro Odometry &amp; SLAM System&quot;);" line96="        serial.writeLine(`[INIT] WHEELBASE: ${WHEELBASE}m, M_PER_PWM_S: ${M_PER_PWM_S}`);" line97="        serial.writeLine(`[INIT] PIDF: kP=${kP}, kI=${kI}, kD=${kD}, kF=${kF}`);" line98="" line99="        resetPose();" line100="        resetMap();" line101="        lastPIDFTime = control.micros();" line102="        lastOdomTime = control.micros();" line103="        isMoving = false;" line104="    }" line105="" line106="    // ==========================================" line107="    // 5. MOTOR PIDF CONTROL SYSTEM" line108="    // ==========================================" line109="" line110="    /**" line111="     * Low-level raw motor drive." line112="     * Sends PWM directly to motors." line113="     * @param left: Left motor PWM (-255 to 255)" line114="     * @param right: Right motor PWM (-255 to 255)" line115="     */" line116="    export function rawDrive(left: number, right: number): void {" line117="        let l = Math.constrain(left, -255, 255);" line118="        let r = Math.constrain(right, -255, 255);" line119="" line120="        // Clamp to byte values" line121="        motorBuf[1] = l &gt; 0 ? l : 0;" line122="        motorBuf[2] = l &lt; 0 ? -l : 0;" line123="        motorBuf[3] = r &gt; 0 ? r : 0;" line124="        motorBuf[4] = r &lt; 0 ? -r : 0;" line125="" line126="        pins.i2cWriteBuffer(PWM_ADD, motorBuf);" line127="" line128="        motorLeftActual = l;" line129="        motorRightActual = r;" line130="    }" line131="" line132="    /**" line133="     * Set target motor speeds for PIDF control." line134="     * @param left: Target left motor PWM (-255 to 255)" line135="     * @param right: Target right motor PWM (-255 to 255)" line136="     */" line137="    export function setMotorTarget(left: number, right: number): void {" line138="        motorLeftTarget = Math.constrain(left, -255, 255);" line139="        motorRightTarget = Math.constrain(right, -255, 255);" line140="    }" line141="" line142="    /**" line143="     * PIDF Motor Controller Update Loop." line144="     * Call this regularly (10-100 Hz) to maintain motor synchronization." line145="     */" line146="    export function updateMotorPIDF(): void {" line147="        let now = control.micros();" line148="        let dt = (now - lastPIDFTime) / 1000000.0;" line149="        if (dt &lt;= 0) dt = 0.001;" line150="        lastPIDFTime = now;" line151="" line152="        // Left Motor PIDF" line153="        let leftError = motorLeftTarget - motorLeftActual;" line154="        leftIntegral += leftError * dt;" line155="        leftIntegral = Math.constrain(leftIntegral, -100, 100);  // Anti-windup" line156="        let leftDerivative = (leftError - leftPrevError) / dt;" line157="        leftPrevError = leftError;" line158="" line159="        let leftOutput = kP * leftError + kI * leftIntegral + kD * leftDerivative;" line160="        let leftPWM = motorLeftTarget + leftOutput;" line161="" line162="        // Right Motor PIDF" line163="        let rightError = motorRightTarget - motorRightActual;" line164="        rightIntegral += rightError * dt;" line165="        rightIntegral = Math.constrain(rightIntegral, -100, 100);" line166="        let rightDerivative = (rightError - rightPrevError) / dt;" line167="        rightPrevError = rightError;" line168="" line169="        let rightOutput = kP * rightError + kI * rightIntegral + kD * rightDerivative;" line170="        let rightPWM = motorRightTarget + rightOutput;" line171="" line172="        // Apply friction compensation" line173="        if (leftPWM &gt; 0 &amp;&amp; leftPWM &lt; kF) leftPWM = kF;" line174="        if (leftPWM &lt; 0 &amp;&amp; leftPWM &gt; -kF) leftPWM = -kF;" line175="        if (rightPWM &gt; 0 &amp;&amp; rightPWM &lt; kF) rightPWM = kF;" line176="        if (rightPWM &lt; 0 &amp;&amp; rightPWM &gt; -kF) rightPWM = -kF;" line177="" line178="        rawDrive(leftPWM, rightPWM);" line179="    }" line180="" line181="    /**" line182="     * Motor synchronization - make sure both motors run at same speed." line183="     * Useful for straight-line driving." line184="     */" line185="    export function syncMotors(): void {" line186="        // Measure current motor speeds and adjust" line187="        setMotorTarget(motorLeftTarget, motorRightTarget);" line188="        updateMotorPIDF();" line189="    }" line190="" line191="    // ==========================================" line192="    // 6. SONAR SENSOR" line193="    // ==========================================" line194="" line195="    /**" line196="     * Get filtered sonar distance in centimeters." line197="     * Returns median of last 5 readings to eliminate noise." line198="     */" line199="    export function getSonar(): number {" line200="        // Trigger sonar" line201="        pins.digitalWritePin(DigitalPin.P16, 0);" line202="        control.waitMicros(2);" line203="        pins.digitalWritePin(DigitalPin.P16, 1);" line204="        control.waitMicros(10);" line205="        pins.digitalWritePin(DigitalPin.P16, 0);" line206="" line207="        // Measure echo (timeout at 25ms)" line208="        let d = pins.pulseIn(DigitalPin.P15, PulseValue.High, 25000) / 58;" line209="" line210="        // Validate and store" line211="        if (d &gt; 2 &amp;&amp; d &lt; 400) {" line212="            sonarHistory[sonarIdx] = d;" line213="            sonarIdx = (sonarIdx + 1) % 5;" line214="        }" line215="" line216="        // Return median" line217="        let sorted = sonarHistory.slice().sort((a, b) =&gt; a - b);" line218="        return sorted[2];" line219="    }" line220="" line221="    /**" line222="     * Get sonar distance in meters." line223="     */" line224="    export function getSonarMeters(): number {" line225="        return getSonar() / 100.0;" line226="    }" line227="" line228="    // ==========================================" line229="    // 7. ODOMETRY &amp; DEAD RECKONING" line230="    // ==========================================" line231="" line232="    /**" line233="     * Update robot pose using dead reckoning." line234="     * Call this regularly with motor PWM values." line235="     * @param lp: Left motor actual PWM" line236="     * @param rp: Right motor actual PWM" line237="     */" line238="    export function updatePose(lp: number, rp: number): void {" line239="        let now2 = control.micros();" line240="        let dt2 = (now2 - lastOdomTime) / 1000000.0;" line241="        if (dt2 &lt;= 0) dt2 = 0.001;" line242="        lastOdomTime = now2;" line243="" line244="        // Convert PWM to velocity (m/s)" line245="        let vL = lp * M_PER_PWM_S;" line246="        let vR = rp * M_PER_PWM_S;" line247="" line248="        // Calculate linear and angular velocity" line249="        let vLinear = (vR + vL) / 2.0;" line250="        let vAngular = (vR - vL) / WHEELBASE;" line251="" line252="        // Update heading" line253="        theta += vAngular * dt2;" line254="" line255="        // Wrap theta to [-π, π]" line256="        while (theta &gt; Math.PI) theta -= 2 * Math.PI;" line257="        while (theta &lt; -Math.PI) theta += 2 * Math.PI;" line258="" line259="        // Update position in global frame" line260="        x += vLinear * Math.cos(theta) * dt2;" line261="        y += vLinear * Math.sin(theta) * dt2;" line262="    }" line263="" line264="    /**" line265="     * Get current robot pose." line266="     * @return {x, y, theta}" line267="     */" line268="    export function getPose(): { x: number, y: number, theta: number } {" line269="        return { x: x, y: y, theta: theta };" line270="    }" line271="" line272="    /**" line273="     * Get heading in degrees." line274="     */" line275="    export function getHeadingDegrees(): number {" line276="        return theta * 57.2957795;  // rad to deg" line277="    }" line278="" line279="    /**" line280="     * Get distance from origin." line281="     */" line282="    export function getDistanceFromOrigin(): number {" line283="        return Math.sqrt(x * x + y * y);" line284="    }" line285="" line286="    /**" line287="     * Reset pose to origin." line288="     */" line289="    export function resetPose(): void {" line290="        x = 0.0;" line291="        y = 0.0;" line292="        theta = 0.0;" line293="        lastOdomTime = control.micros();" line294="    }" line295="" line296="    /**" line297="     * Manually set pose (for loop closure correction)." line298="     */" line299="    export function setPose(px: number, py: number, ptheta: number): void {" line300="        x = px;" line301="        y = py;" line302="        theta = ptheta;" line303="    }" line304="" line305="    // ==========================================" line306="    // 8. SLAM MAPPING" line307="    // ==========================================" line308="" line309="    /**" line310="     * Update occupancy grid map using sonar." line311="     * Projects sonar reading into global map coordinates." line312="     */" line313="    export function updateMap(): void {" line314="        let d_meters = getSonarMeters();" line315="" line316="        // Ignore out-of-range readings" line317="        if (d_meters &lt; SONAR_MIN_RANGE || d_meters &gt; SONAR_MAX_RANGE) return;" line318="" line319="        // Project sensor hit into global coordinates" line320="        let wallX = x + (d_meters * Math.cos(theta));" line321="        let wallY = y + (d_meters * Math.sin(theta));" line322="" line323="        // Convert to grid coordinates" line324="        let gx = Math.floor(wallX / GRID_RES) + (MAP_DIM / 2);" line325="        let gy = Math.floor(wallY / GRID_RES) + (MAP_DIM / 2);" line326="" line327="        // Update grid if in bounds" line328="        if (gx &gt;= 0 &amp;&amp; gx &lt; MAP_DIM &amp;&amp; gy &gt;= 0 &amp;&amp; gy &lt; MAP_DIM) {" line329="            let index = gy * MAP_DIM + gx;" line330="            if (mapGrid[index] &lt; 250) {" line331="                mapGrid[index] += 25;  // Requires ~4 hits for certainty" line332="            }" line333="        }" line334="    }" line335="" line336="    /**" line337="     * Get occupancy probability of a grid cell (0-255)." line338="     */" line339="    export function getGridCell(gx: number, gy: number): number {" line340="        if (gx &lt; 0 || gx &gt;= MAP_DIM || gy &lt; 0 || gy &gt;= MAP_DIM) return 0;" line341="        return mapGrid[gy * MAP_DIM + gx];" line342="    }" line343="" line344="    /**" line345="     * Manually set a grid cell value." line346="     */" line347="    export function setGridCell(gx: number, gy: number, value: number): void {" line348="        if (gx &lt; 0 || gx &gt;= MAP_DIM || gy &lt; 0 || gy &gt;= MAP_DIM) return;" line349="        mapGrid[gy * MAP_DIM + gx] = Math.constrain(value, 0, 255);" line350="    }" line351="" line352="    /**" line353="     * Clear the entire map." line354="     */" line355="    export function resetMap(): void {" line356="        for (let i = 0; i &lt; MAP_DIM * MAP_DIM; i++) {" line357="            mapGrid[i] = 0;" line358="        }" line359="    }" line360="" line361="    // ==========================================" line362="    // 9. HIGH-LEVEL MOVEMENT COMMANDS" line363="    // ==========================================" line364="" line365="    /**" line366="     * Drive straight for a distance (cm)." line367="     * Uses odometry to track distance." line368="     * @param distanceCm: Distance in centimeters" line369="     * @param speed: Motor PWM (default 150)" line370="     */" line371="    export function driveStraight(distanceCm: number, speed: number = 150): void {" line372="        let targetDist = distanceCm / 100.0;  // Convert to meters" line373="        resetPose();" line374="        isMoving = true;" line375="        movementMode = 1;" line376="" line377="        while (isMoving &amp;&amp; getDistanceFromOrigin() &lt; targetDist) {" line378="            setMotorTarget(speed, speed);" line379="            updateMotorPIDF();" line380="            updatePose(motorLeftActual, motorRightActual);" line381="            updateMap();" line382="            basic.pause(10);" line383="        }" line384="" line385="        rawDrive(0, 0);" line386="        isMoving = false;" line387="    }" line388="" line389="    /**" line390="     * Turn by angle (degrees)." line391="     * Uses odometry to track rotation." line392="     * @param angleDeg: Angle in degrees (positive = left, negative = right)" line393="     * @param speed: Motor PWM (default 100)" line394="     */" line395="    export function turnByAngle(angleDeg: number, speed: number = 100): void {" line396="        let targetRad = angleDeg * 0.0174533;  // deg to rad" line397="        let initialTheta = theta;" line398="        isMoving = true;" line399="        movementMode = 2;" line400="" line401="        while (isMoving) {" line402="            let rotated = Math.abs(theta - initialTheta);" line403="            if (rotated &gt;= Math.abs(targetRad)) break;" line404="" line405="            if (angleDeg &gt; 0) {" line406="                setMotorTarget(-speed, speed);  // Turn left" line407="            } else {" line408="                setMotorTarget(speed, -speed);  // Turn right" line409="            }" line410="" line411="            updateMotorPIDF();" line412="            updatePose(motorLeftActual, motorRightActual);" line413="            basic.pause(10);" line414="        }" line415="" line416="        rawDrive(0, 0);" line417="        isMoving = false;" line418="    }" line419="" line420="    /**" line421="     * Drive in an arc." line422="     * @param distanceCm: Arc length in cm" line423="     * @param radiusM: Turn radius in meters (positive = left, negative = right)" line424="     */" line425="    export function driveArc(distanceCm: number, radiusM: number, speed: number = 150): void {" line426="        let arcDist = distanceCm / 100.0;" line427="        let initialDist = getDistanceFromOrigin();" line428="        isMoving = true;" line429="" line430="        while (isMoving &amp;&amp; (getDistanceFromOrigin() - initialDist) &lt; arcDist) {" line431="            // Differential drive for arc" line432="            let angularRate = speed / radiusM;" line433="            let leftSpeed = speed - (angularRate * WHEELBASE / 2);" line434="            let rightSpeed = speed + (angularRate * WHEELBASE / 2);" line435="" line436="            setMotorTarget(leftSpeed, rightSpeed);" line437="            updateMotorPIDF();" line438="            updatePose(motorLeftActual, motorRightActual);" line439="            updateMap();" line440="            basic.pause(10);" line441="        }" line442="" line443="        rawDrive(0, 0);" line444="        isMoving = false;" line445="    }" line446="" line447="    /**" line448="     * Drive to absolute position using SLAM." line449="     * @param targetX: Target X in meters" line450="     * @param targetY: Target Y in meters" line451="     * @param speed: Motor PWM (default 150)" line452="     */" line453="    export function driveTo(targetX: number, targetY: number, speed: number = 150): void {" line454="        isMoving = true;" line455="" line456="        while (isMoving) {" line457="            // Calculate distance to target" line458="            let dx = targetX - x;" line459="            let dy = targetY - y;" line460="            let dist = Math.sqrt(dx * dx + dy * dy);" line461="" line462="            if (dist &lt; DISTANCE_TOLERANCE) break;" line463="" line464="            // Calculate angle to target" line465="            let targetAngle2 = Math.atan2(dy, dx);" line466="            let angleDiff = targetAngle2 - theta;" line467="" line468="            // Wrap angle difference" line469="            while (angleDiff &gt; Math.PI) angleDiff -= 2 * Math.PI;" line470="            while (angleDiff &lt; -Math.PI) angleDiff += 2 * Math.PI;" line471="" line472="            // Proportional control" line473="            let leftSpeed2 = speed * (1 - angleDiff * 0.5);" line474="            let rightSpeed2 = speed * (1 + angleDiff * 0.5);" line475="" line476="            setMotorTarget(leftSpeed2, rightSpeed2);" line477="            updateMotorPIDF();" line478="            updatePose(motorLeftActual, motorRightActual);" line479="            updateMap();" line480="            basic.pause(10);" line481="        }" line482="" line483="        rawDrive(0, 0);" line484="        isMoving = false;" line485="    }" line486="" line487="    /**" line488="     * Rotate to face absolute heading." line489="     * @param targetHeadingDeg: Target heading in degrees (0-360)" line490="     * @param speed: Motor PWM (default 100)" line491="     */" line492="    export function rotateTo(targetHeadingDeg: number, speed: number = 100): void {" line493="        let targetRad2 = targetHeadingDeg * 0.0174533;" line494="        isMoving = true;" line495="" line496="        while (isMoving) {" line497="            let angleDiff2 = targetRad2 - theta;" line498="" line499="            // Wrap to [-π, π]" line500="            while (angleDiff2 &gt; Math.PI) angleDiff2 -= 2 * Math.PI;" line501="            while (angleDiff2 &lt; -Math.PI) angleDiff2 += 2 * Math.PI;" line502="" line503="            if (Math.abs(angleDiff2) &lt; ANGLE_TOLERANCE * 0.0174533) break;" line504="" line505="            if (angleDiff2 &gt; 0) {" line506="                setMotorTarget(-speed, speed);" line507="            } else {" line508="                setMotorTarget(speed, -speed);" line509="            }" line510="" line511="            updateMotorPIDF();" line512="            updatePose(motorLeftActual, motorRightActual);" line513="            basic.pause(10);" line514="        }" line515="" line516="        rawDrive(0, 0);" line517="        isMoving = false;" line518="    }" line519="" line520="    /**" line521="     * Stop all motors immediately." line522="     */" line523="    export function stop(): void {" line524="        rawDrive(0, 0);" line525="        isMoving = false;" line526="        setMotorTarget(0, 0);" line527="    }" line528="" line529="    // ==========================================" line530="    // 10. RGB LED CONTROL" line531="    // ==========================================" line532="" line533="    export enum RGBColor {" line534="        OFF = 0," line535="        Red = 1," line536="        Green = 2," line537="        Blue = 3," line538="        White = 4," line539="        Cyan = 5," line540="        Magenta = 6," line541="        Yellow = 7" line542="    }" line543="" line544="    /**" line545="     * Set RGB LED color." line546="     */" line547="    export function setRGB(color: RGBColor): void {" line548="        let s = 0, g = 0, b = 0;" line549="" line550="        switch (color) {" line551="            case RGBColor.Red: s = 255; break;" line552="            case RGBColor.Green: g = 255; break;" line553="            case RGBColor.Blue: b = 255; break;" line554="            case RGBColor.White: s = 255; g = 255; b = 255; break;" line555="            case RGBColor.Cyan: g = 255; b = 255; break;" line556="            case RGBColor.Magenta: s = 255; b = 255; break;" line557="            case RGBColor.Yellow: s = 255; g = 255; break;" line558="        }" line559="" line560="        rgbBuf[1] = s;" line561="        rgbBuf[2] = g;" line562="        rgbBuf[3] = b;" line563="        pins.i2cWriteBuffer(PWM_ADD, rgbBuf);" line564="    }" line565="" line566="    /**" line567="     * Set RGB with raw values." line568="     */" line569="    export function setRGBRaw(r: number, g: number, b: number): void {" line570="        rgbBuf[1] = Math.constrain(r, 0, 255);" line571="        rgbBuf[2] = Math.constrain(g, 0, 255);" line572="        rgbBuf[3] = Math.constrain(b, 0, 255);" line573="        pins.i2cWriteBuffer(PWM_ADD, rgbBuf);" line574="    }" line575="" line576="    // ==========================================" line577="    // 11. DEBUG &amp; TELEMETRY" line578="    // ==========================================" line579="" line580="    /**" line581="     * Print current pose to serial." line582="     */" line583="    export function printPose(): void {" line584="        serial.writeLine(`[POSE] X: ${Math.round(x * 100)}cm, Y: ${Math.round(y * 100)}cm, θ: ${Math.round(getHeadingDegrees())}°`);" line585="    }" line586="" line587="    /**" line588="     * Print sonar reading to serial." line589="     */" line590="    export function printSonar(): void {" line591="        let e = getSonar();" line592="    }" line593="" line594="    /**" line595="     * Print motor state to serial." line596="     */" line597="    export function printMotorState(): void {" line598="        serial.writeLine(`[MOTOR] L: ${motorLeftActual}/${motorLeftTarget}, R: ${motorRightActual}/${motorRightTarget}, Err: ${motorLeftError}/${motorRightError}`);" line599="    }" line600="" line601="    /**" line602="     * Export SLAM map as ASCII to serial." line603="     */" line604="    export function exportMapToSerial(): void {" line605="        serial.writeLine(&quot;\n========== SLAM MAP ==========&quot;);" line606="        serial.writeLine(`Pose: X=${Math.round(x * 100)}cm Y=${Math.round(y * 100)}cm θ=${Math.round(getHeadingDegrees())}°`);" line607="        serial.writeLine(&quot;&quot;);" line608="" line609="        for (let row = 0; row &lt; MAP_DIM; row++) {" line610="            let line = &quot;&quot;;" line611="            for (let col = 0; col &lt; MAP_DIM; col++) {" line612="                let cellData = mapGrid[row * MAP_DIM + col];" line613="                let robotGx = Math.floor(x / GRID_RES) + (MAP_DIM / 2);" line614="                let robotGy = Math.floor(y / GRID_RES) + (MAP_DIM / 2);" line615="" line616="                if (col === robotGx &amp;&amp; row === robotGy) {" line617="                    line += &quot;R &quot;;" line618="                } else if (cellData &gt; 100) {" line619="                    line += &quot;█ &quot;;" line620="                } else if (cellData &gt; 25) {" line621="                    line += &quot;▒ &quot;;" line622="                } else {" line623="                    line += &quot;. &quot;;" line624="                }" line625="            }" line626="            serial.writeLine(line);" line627="        }" line628="        serial.writeLine(&quot;==============================\n&quot;);" line629="    }" line630="" line631="    /**" line632="     * Export telemetry as JSON." line633="     */" line634="    export function exportTelemetryJSON(): string {" line635="        let json = `{&quot;pose&quot;:{&quot;x&quot;:${x},&quot;y&quot;:${y},&quot;theta&quot;:${theta},&quot;heading_deg&quot;:${getHeadingDegrees()}},&quot;motors&quot;:{&quot;left&quot;:${motorLeftActual},&quot;right&quot;:${motorRightActual},&quot;left_target&quot;:${motorLeftTarget},&quot;right_target&quot;:${motorRightTarget}},&quot;sonar&quot;:${getSonar()},&quot;distance_origin&quot;:${getDistanceFromOrigin()}}`;" line636="        serial.writeLine(json);" line637="        return json;" line638="    }" line639="}" numlines="640"></mutation></block></statement></block></xml>