<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="!e`OhA]}D}0U]^#R(NC#" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="40n$vlSZ$Cm%RH72kqW="><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace TinybitPro {" line1="" line2="    // ==========================================" line3="    // 1. CALIBRATION &amp; TUNING" line4="    // ==========================================" line5="    export let WHEELBASE = 0.082;         // 8.2cm" line6="    export let M_PER_PWM_S = 0.00215;    // Meters per PWM unit per sec" line7="" line8="    // GEARBOX TUNING" line9="    export let kF = 60;                  // Minimum &quot;Kick&quot; to move gears (45-70)" line10="    export let SLEW_RATE = 15;           // Max PWM change per 20ms" line11="    export let DISTANCE_TOLERANCE = 0.03; // 3cm" line12="    export let ANGLE_TOLERANCE = 0.05;    // Radians (~3 degrees)" line13="" line14="    // SLAM SETUP" line15="    export let GRID_RES = 0.05;" line16="    export let MAP_DIM = 40;" line17="" line18="    // ==========================================" line19="    // 2. INTERNAL STATE" line20="    // ==========================================" line21="    export let x = 0.0, y = 0.0, theta = 0.0;" line22="    let motorLeftTarget = 0, motorRightTarget = 0;" line23="    let motorLeftActual = 0, motorRightActual = 0;" line24="" line25="    let lastOdomTime = control.micros();" line26="    let isMoving = false;" line27="" line28="    // Directional safety (prevents gear grinding/oscillation)" line29="    let car_flag_old = 0;" line30="    let car_flag_new = 0;" line31="" line32="    const PWM_ADD = 0x01;" line33="    const MOTOR_REG = 0x02;" line34="    const RGB_REG = 0x01;" line35="" line36="    let motorBuf = pins.createBuffer(5);" line37="    motorBuf[0] = MOTOR_REG;" line38="    let mapGrid = pins.createBuffer(MAP_DIM * MAP_DIM);" line39="" line40="    // ==========================================" line41="    // 3. LOW-LEVEL HARDWARE CONTROL" line42="    // ==========================================" line43="" line44="    /**" line45="     * Sends raw PWM to the I2C controller with Gearbox Safety." line46="     */" line47="    export function rawDrive(left: number, right: number): void {" line48="        let l = Math.constrain(Math.round(left), -255, 255);" line49="        let r = Math.constrain(Math.round(right), -255, 255);" line50="" line51="        // Gearbox Logic: Boost small signals to kF so gears actually turn" line52="        if (l != 0 &amp;&amp; Math.abs(l) &lt; kF) l = (l &gt; 0) ? kF : -kF;" line53="        if (r != 0 &amp;&amp; Math.abs(r) &lt; kF) r = (r &gt; 0) ? kF : -r;" line54="" line55="        // Zero-out noise" line56="        if (Math.abs(l) &lt; 10) l = 0;" line57="        if (Math.abs(r) &lt; 10) r = 0;" line58="" line59="        // Directional State Tracking" line60="        if (l &gt;= 0 &amp;&amp; r &gt;= 0) car_flag_new = 0;" line61="        else if (l &lt; 0 &amp;&amp; r &lt; 0) car_flag_new = 1;" line62="        else if (l &gt; 0 &amp;&amp; r &lt; 0) car_flag_new = 2;" line63="        else car_flag_new = 3;" line64="" line65="        // SAFETY: If direction flipped, stop briefly to protect gearbox" line66="        if (car_flag_new != car_flag_old) {" line67="            let stopBuf = pins.createBuffer(5);" line68="            stopBuf[0] = MOTOR_REG; // All zeros" line69="            pins.i2cWriteBuffer(PWM_ADD, stopBuf);" line70="            basic.pause(100);" line71="            car_flag_old = car_flag_new;" line72="        }" line73="" line74="        motorBuf[1] = l &gt; 0 ? l : 0;" line75="        motorBuf[2] = l &lt; 0 ? -l : 0;" line76="        motorBuf[3] = r &gt; 0 ? r : 0;" line77="        motorBuf[4] = r &lt; 0 ? -r : 0;" line78="        " line79="        pins.i2cWriteBuffer(PWM_ADD, motorBuf);" line80="        motorLeftActual = l;" line81="        motorRightActual = r;" line82="    }" line83="" line84="    /**" line85="     * Ramps motor speed to target to prevent high-frequency oscillation." line86="     */" line87="    export function updateMotorLogic(): void {" line88="        let lDiff = motorLeftTarget - motorLeftActual;" line89="        let rDiff = motorRightTarget - motorRightActual;" line90="" line91="        // Apply Slew Rate (Smoothing)" line92="        if (Math.abs(lDiff) &gt; SLEW_RATE) motorLeftActual += (lDiff &gt; 0 ? SLEW_RATE : -SLEW_RATE);" line93="        else motorLeftActual = motorLeftTarget;" line94="" line95="        if (Math.abs(rDiff) &gt; SLEW_RATE) motorRightActual += (rDiff &gt; 0 ? SLEW_RATE : -SLEW_RATE);" line96="        else motorRightActual = motorRightTarget;" line97="" line98="        rawDrive(motorLeftActual, motorRightActual);" line99="    }" line100="" line101="    // ==========================================" line102="    // 4. ODOMETRY &amp; SLAM" line103="    // ==========================================" line104="" line105="    export function updatePose(): void {" line106="        let now = control.micros();" line107="        let dt = (now - lastOdomTime) / 1000000.0;" line108="        if (dt &lt;= 0) dt = 0.001;" line109="        lastOdomTime = now;" line110="" line111="        let vL = motorLeftActual * M_PER_PWM_S;" line112="        let vR = motorRightActual * M_PER_PWM_S;" line113="" line114="        let vLinear = (vR + vL) / 2.0;" line115="        let vAngular = (vR - vL) / WHEELBASE;" line116="" line117="        theta += vAngular * dt;" line118="        // Normalize Angle" line119="        while (theta &gt; Math.PI) theta -= 2 * Math.PI;" line120="        while (theta &lt; -Math.PI) theta += 2 * Math.PI;" line121="" line122="        x += vLinear * Math.cos(theta) * dt;" line123="        y += vLinear * Math.sin(theta) * dt;" line124="    }" line125="" line126="    export function getSonar(): number {" line127="        pins.digitalWritePin(DigitalPin.P16, 0);" line128="        control.waitMicros(2);" line129="        pins.digitalWritePin(DigitalPin.P16, 1);" line130="        control.waitMicros(10);" line131="        pins.digitalWritePin(DigitalPin.P16, 0);" line132="        let d = pins.pulseIn(DigitalPin.P15, PulseValue.High, 25000);" line133="        return d / 58;" line134="    }" line135="" line136="    // ==========================================" line137="    // 5. NAVIGATION COMMANDS" line138="    // ==========================================" line139="" line140="    export function driveStraight(distanceCm: number, speed: number = 150): void {" line141="        let targetDist = distanceCm / 100.0;" line142="        let startX = x, startY = y;" line143="        isMoving = true;" line144="" line145="        while (isMoving) {" line146="            updatePose();" line147="            let traveled = Math.sqrt(Math.pow(x - startX, 2) + Math.pow(y - startY, 2));" line148="            if (traveled &gt;= targetDist) break;" line149="" line150="            motorLeftTarget = speed;" line151="            motorRightTarget = speed;" line152="            updateMotorLogic();" line153="            basic.pause(20);" line154="        }" line155="        stop();" line156="    }" line157="" line158="    export function turnByAngle(angleDeg: number, speed: number = 120): void {" line159="        let targetRad = angleDeg * (Math.PI / 180);" line160="        let startTheta = theta;" line161="        isMoving = true;" line162="" line163="        while (isMoving) {" line164="            updatePose();" line165="            let diff = Math.abs(theta - startTheta);" line166="            if (diff &gt;= Math.abs(targetRad)) break;" line167="" line168="            if (angleDeg &gt; 0) {" line169="                motorLeftTarget = -speed; motorRightTarget = speed;" line170="            } else {" line171="                motorLeftTarget = speed; motorRightTarget = -speed;" line172="            }" line173="            updateMotorLogic();" line174="            basic.pause(20);" line175="        }" line176="        stop();" line177="    }" line178="" line179="    export function stop(): void {" line180="        motorLeftTarget = 0;" line181="        motorRightTarget = 0;" line182="        rawDrive(0, 0);" line183="        isMoving = false;" line184="    }" line185="" line186="    export function init(): void {" line187="        x = 0; y = 0; theta = 0;" line188="        lastOdomTime = control.micros();" line189="        stop();" line190="        for (let i = 0; i &lt; MAP_DIM * MAP_DIM; i++) mapGrid[i] = 0;" line191="    }" line192="}" numlines="193"></mutation></block></statement></block></xml>